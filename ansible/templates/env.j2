# AI English Analyzer — Environment Variables
# Жасалған: Ansible арқылы автоматты түрде
# Өзгертпе: playbook.yml vars арқылы жаңарт

# ── Database ──────────────────────────────────────────────────
{% if rds_endpoint is defined and rds_endpoint %}
# AWS RDS PostgreSQL (managed database)
DATABASE_URL=postgresql://{{ db_username | default('ai_user') }}:{{ db_password | default('ai_password') }}@{{ rds_endpoint }}:5432/{{ db_name | default('ai_english_analyzer') }}
{% else %}
# Docker PostgreSQL (жергілікті контейнер)
DATABASE_URL=postgresql://{{ db_username | default('ai_user') }}:{{ db_password | default('ai_password') }}@db:5432/{{ db_name | default('ai_english_analyzer') }}
{% endif %}

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET={{ jwt_secret | default('change-this-secret') }}

# ── AI APIs ───────────────────────────────────────────────────
GEMINI_API_KEY={{ gemini_api_key | default('') }}

{% if openai_api_key is defined %}
OPENAI_API_KEY={{ openai_api_key }}
{% endif %}

# ── Monitoring ────────────────────────────────────────────────
GRAFANA_PASSWORD={{ grafana_password | default('admin123') }}

# ── App ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
NEXT_TELEMETRY_DISABLED=1
