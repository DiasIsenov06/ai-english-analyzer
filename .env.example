# База данных
# Docker: docker-compose задаёт DATABASE_URL автоматически
# Локально (без Docker): укажи URL к PostgreSQL
DATABASE_URL="postgresql://ai_user:ai_password@localhost:5432/ai_english_analyzer"

# JWT Secret (сгенерируйте свой: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# LLM API (для AI-плана и Daily Training). Используется первый доступный:
# Gemini (бесплатный tier) — aistudio.google.com/app/apikey
# OpenAI — platform.openai.com
# GEMINI_API_KEY="AIzaSy..."
# GEMINI_MODEL="gemini-2.5-flash" (по умолчанию; или gemini-2.0-flash, gemini-2.0-flash-lite)
# OPENAI_API_KEY="sk-..."
